{
  "name": "gazania",
  "type": "module",
  "version": "0.8.0",
  "packageManager": "pnpm@10.33.0",
  "description": "Gazania lets you write GraphQL operations as TypeScript code with full type inference, autocompletion, and compile-time error checking.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Teages/gazania.git"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.mts",
      "import": "./dist/codegen/index.mjs"
    }
  },
  "module": "./dist/index.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.mts"
      ],
      "codegen": [
        "./dist/codegen/index.d.mts"
      ]
    }
  },
  "bin": {
    "gazania": "./dist/cli/index.mjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "obuild",
    "prepack": "pnpm run build",
    "dev": "vitest dev",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "pnpm run build && vitest run --coverage",
    "typecheck": "tsc --build --noEmit",
    "play:prepare": "obuild --stub",
    "play": "pnpm -C playground run play",
    "docs:dev": "pnpm -C docs run dev",
    "docs:build": "pnpm -C docs run build",
    "docs:preview": "pnpm -C docs run preview"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2",
    "graphql": "^16.13.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/estree": "^1.0.8",
    "@types/node": "^24.12.0",
    "@vitest/coverage-v8": "^4.1.4",
    "changelogen": "^0.6.2",
    "eslint": "^10.2.1",
    "jiti": "2.6.1",
    "obuild": "^0.4.33",
    "tsnapi": "^0.3.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
